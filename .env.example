# Porta usada no computador local.
PORT=3000

# Connection string do MongoDB Atlas.
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/nome_do_projeto

# Chave secreta usada para assinar e verificar tokens JWT.
JWT_SECRET=troque_essa_chave_por_uma_chave_grande

# Tempo de validade do token JWT.
JWT_EXPIRES_IN=1d

# Custo usado pelo bcrypt para gerar o hash da senha.
BCRYPT_SALT_ROUNDS=10
